 109:Core/Src/main.c ****   uint8_t send_default_len = sizeof(send_default);
 110:Core/Src/main.c ****   HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_4);
 111:Core/Src/main.c ****   /* USER CODE END 2 */
 112:Core/Src/main.c **** 
 113:Core/Src/main.c ****   /* Infinite loop */
 114:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 115:Core/Src/main.c ****   while (1)
 116:Core/Src/main.c ****   {
 117:Core/Src/main.c ****         /* Fade in */
 118:Core/Src/main.c ****         for (uint16_t duty = 0; duty < 1000; duty++) {
 119:Core/Src/main.c ****             __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_4, duty);
 120:Core/Src/main.c ****             HAL_Delay(1);  // controls fade speed
 121:Core/Src/main.c ****         }
 122:Core/Src/main.c **** 
 123:Core/Src/main.c ****         /* Fade out */
 124:Core/Src/main.c ****         for (uint16_t duty = 1000; duty > 0; duty--) {
 125:Core/Src/main.c ****             __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_4, duty);
 126:Core/Src/main.c ****             HAL_Delay(1);
 127:Core/Src/main.c ****         }
 128:Core/Src/main.c ****     /* USER CODE END WHILE */
 129:Core/Src/main.c ****       CDC_Transmit_FS(send_default, send_default_len);
 130:Core/Src/main.c ****       HAL_Delay(100);
 131:Core/Src/main.c ****     /* USER CODE BEGIN 3 */
 132:Core/Src/main.c ****   }
 133:Core/Src/main.c ****   /* USER CODE END 3 */
 134:Core/Src/main.c **** }
