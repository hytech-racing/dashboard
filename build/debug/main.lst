 432:Core/Src/main.c ****     {
 433:Core/Src/main.c ****         char error_msg[] = "CAN Error Warning\r\n";
 434:Core/Src/main.c ****         CDC_Transmit_FS((uint8_t *)error_msg, strlen(error_msg));
 435:Core/Src/main.c ****     }
