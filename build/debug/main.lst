 118:Core/Src/main.c ****   /* Infinite loop */
 119:Core/Src/main.c ****   /* USER CODE BEGIN WHILE */
 120:Core/Src/main.c ****   while (1)
 121:Core/Src/main.c ****   {
 122:Core/Src/main.c ****         /* Fade in */
 123:Core/Src/main.c ****         for (uint16_t duty = 0; duty < 1000; duty++) {
 124:Core/Src/main.c ****             __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_4, duty);
 125:Core/Src/main.c ****             HAL_Delay(1);  // controls fade speed
 126:Core/Src/main.c ****         }
 127:Core/Src/main.c **** 
 128:Core/Src/main.c ****         /* Fade out */
 129:Core/Src/main.c ****         for (uint16_t duty = 1000; duty > 0; duty--) {
 130:Core/Src/main.c ****             __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_4, duty);
 131:Core/Src/main.c ****             HAL_Delay(1);
 132:Core/Src/main.c ****         }
