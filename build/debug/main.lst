 391:Core/Src/main.c **** void HAL_FDCAN_RxFifo0Callback(FDCAN_HandleTypeDef *hfdcan, uint32_t RxFifo0ITs)
 392:Core/Src/main.c **** {
 393:Core/Src/main.c ****     if (RxFifo0ITs & FDCAN_IT_RX_FIFO0_NEW_MESSAGE)
 394:Core/Src/main.c ****     {
 395:Core/Src/main.c ****         /* Retrieve Rx messages from RX FIFO0 */
 396:Core/Src/main.c ****         if (HAL_FDCAN_GetRxMessage(hfdcan, FDCAN_RX_FIFO0, &RxHeader, RxData) != HAL_OK)
 397:Core/Src/main.c ****         {
 398:Core/Src/main.c ****             Error_Handler();
 399:Core/Src/main.c ****         }
 400:Core/Src/main.c **** 
 401:Core/Src/main.c ****         /* Convert DLC to actual data length */
 402:Core/Src/main.c ****         uint8_t data_length = (RxHeader.DataLength >> 16) & 0xF;
 403:Core/Src/main.c **** 
 404:Core/Src/main.c ****         /* Print received message over USB */
 405:Core/Src/main.c ****         char msg[64];
 406:Core/Src/main.c ****         int len = snprintf(msg, sizeof(msg), "ID: 0x%03X, DLC: %d, Data: ", RxHeader.Identifier, da
 407:Core/Src/main.c ****         for (int i = 0; i < data_length; i++)
 408:Core/Src/main.c ****         {
 409:Core/Src/main.c ****             len += snprintf(msg + len, sizeof(msg) - len, "%02X ", RxData[i]);
 410:Core/Src/main.c ****         }
 411:Core/Src/main.c ****         snprintf(msg + len, sizeof(msg) - len, "\r\n");
 412:Core/Src/main.c **** 
 413:Core/Src/main.c ****         CDC_Transmit_FS((uint8_t *)msg, strlen(msg));
 414:Core/Src/main.c ****     }
 415:Core/Src/main.c **** 
 416:Core/Src/main.c ****     if (RxFifo0ITs & FDCAN_IT_BUS_OFF)
 417:Core/Src/main.c ****     {
ARM GAS  C:\Users\aticl\AppData\Local\Temp\cczf3dLE.s 			page 10


 418:Core/Src/main.c ****         char error_msg[] = "CAN Bus-Off Error\r\n";
 419:Core/Src/main.c ****         CDC_Transmit_FS((uint8_t *)error_msg, strlen(error_msg));
 420:Core/Src/main.c ****         HAL_FDCAN_Stop(hfdcan);  // Stop the CAN peripheral
 421:Core/Src/main.c ****         HAL_Delay(1000);         // Wait before attempting recovery
 422:Core/Src/main.c ****         HAL_FDCAN_Start(hfdcan); // Restart the CAN peripheral
 423:Core/Src/main.c ****     }
 424:Core/Src/main.c **** 
 425:Core/Src/main.c ****     if (RxFifo0ITs & FDCAN_IT_ERROR_PASSIVE)
 426:Core/Src/main.c ****     {
 427:Core/Src/main.c ****         char error_msg[] = "CAN Error Passive\r\n";
 428:Core/Src/main.c ****         CDC_Transmit_FS((uint8_t *)error_msg, strlen(error_msg));
 429:Core/Src/main.c ****     }
 430:Core/Src/main.c **** 
